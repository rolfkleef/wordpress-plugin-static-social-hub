{
  "name": "rolfkleef/static-social-hub",
  "description": "Static Social Hub is a WordPress plugin that allows you to create a social media feed on your website by fetching and displaying posts from various social media platforms.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "squizlabs/php_codesniffer": "^3.9",
    "wp-coding-standards/wpcs": "^3.1",
    "phpcsstandards/phpcsutils": "^1.0",
    "phpcsstandards/phpcsextra": "^1.2",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "phpunit/phpunit": "^10.0 || ^11.0",
    "yoast/phpunit-polyfills": "^2.0",
    "brain/monkey": "^2.6",
    "php-parallel-lint/php-parallel-lint": "^1.4",
    "wp-phpunit/wp-phpunit": "^6.6"
  },
  "autoload": {
    "psr-4": {
      "StaticSocialHub\\": "plugin/includes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "StaticSocialHub\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "scripts": {
    "lint": "parallel-lint --exclude vendor --exclude node_modules plugin/ tests/",
    "cs": "phpcs --standard=phpcs.xml.dist",
    "cs:fix": "phpcbf --standard=phpcs.xml.dist",
    "test": "phpunit --configuration=phpunit.xml.dist",
    "test:coverage": "phpunit --configuration=phpunit.xml.dist --coverage-text",
    "check-all": ["@lint", "@cs", "@test"]
  },
  "scripts-descriptions": {
    "lint": "Check PHP parse errors",
    "cs": "Run coding standards checks",
    "cs:fix": "Auto-fix coding standards violations",
    "test": "Run PHPUnit tests",
    "test:coverage": "Run PHPUnit tests with coverage report",
    "check-all": "Run all checks"
  }
}
